<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WonderLust</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * {
      font-family: 'Poppins', sans-serif;
    }

    :root {
      --red: #FF385C;
      --dark-red: #E31C5F;
    }

    body {
      padding-top: 76px;
      background: #f8f8f8;
    }

    /* ── Navbar ── */
    .navbar {
      background: #fff;
      box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      transition: all 0.3s;
    }

    .navbar.scrolled {
      padding: 0.5rem 0;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
    }

    .navbar-brand {
      font-size: 1.55rem;
      font-weight: 800;
      color: var(--red) !important;
      display: flex;
      align-items: center;
      gap: 8px;
      letter-spacing: -0.5px;
    }

    .navbar-brand i {
      animation: pulse 2.5s ease-in-out infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        transform: scale(1)
      }

      50% {
        transform: scale(1.15)
      }
    }

    .nav-link {
      color: #333 !important;
      font-weight: 500;
      font-size: 0.9rem;
      padding: 8px 14px !important;
      border-radius: 22px;
      transition: all 0.25s;
      display: flex;
      align-items: center;
      gap: 6px;
      position: relative;
      white-space: nowrap;
    }

    .nav-link:hover {
      background: #f5f5f5;
      color: var(--red) !important;
    }

    .nav-link.active-nav {
      background: var(--red) !important;
      color: #fff !important;
      box-shadow: 0 3px 10px rgba(255, 56, 92, 0.28);
    }

    .nav-link.active-nav:hover {
      background: var(--dark-red) !important;
      color: #fff !important;
    }

    /* Badge on bookings link */
    .nav-badge {
      background: var(--red);
      color: #fff;
      font-size: 0.68rem;
      font-weight: 700;
      border-radius: 50%;
      width: 18px;
      height: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      top: 2px;
      right: 6px;
      border: 2px solid #fff;
    }

    .nav-link.active-nav .nav-badge {
      background: #fff;
      color: var(--red);
      border-color: var(--red);
    }

    /* Divider */
    .nav-divider {
      width: 1px;
      height: 22px;
      background: #e0e0e0;
      margin: 0 6px;
    }

    /* Login / Signup buttons */
    .btn-nav-login {
      border: 2px solid #ddd;
      border-radius: 22px;
      padding: 7px 18px !important;
      font-weight: 600;
      color: #333 !important;
    }

    .btn-nav-login:hover {
      border-color: var(--red);
      color: var(--red) !important;
      background: transparent;
    }

    .btn-nav-signup {
      background: var(--red) !important;
      color: #fff !important;
      border-radius: 22px;
      padding: 7px 20px !important;
      font-weight: 600;
      border: 2px solid transparent;
    }

    .btn-nav-signup:hover {
      background: var(--dark-red) !important;
      box-shadow: 0 4px 12px rgba(255, 56, 92, 0.3);
    }

    /* User avatar chip */
    .user-chip {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 5px 14px;
      border: 1.5px solid #eee;
      border-radius: 22px;
      font-size: 0.86rem;
      font-weight: 600;
      color: #333;
      background: #fafafa;
      max-width: 180px;
    }

    .user-chip .avatar {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: var(--red);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-weight: 800;
      flex-shrink: 0;
    }

    .user-chip .email-text {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .btn-logout {
      color: #999 !important;
      font-size: 0.86rem !important;
      padding: 7px 12px !important;
      border-radius: 22px;
    }

    .btn-logout:hover {
      color: var(--red) !important;
      background: #fff0f2 !important;
    }

    .navbar-toggler {
      border: 2px solid var(--red);
      border-radius: 8px;
      padding: 6px 10px;
    }

    .navbar-toggler:focus {
      box-shadow: 0 0 0 3px rgba(255, 56, 92, 0.2);
    }

    .navbar-toggler-icon {
      background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='%23FF385C' stroke-linecap='round' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
    }

    @media (max-width: 991px) {
      .nav-link {
        margin: 2px 0;
      }

      .nav-divider {
        display: none;
      }

      body {
        padding-top: 70px;
      }
    }

    /* ── Flash Toasts ── */
    .flash-container {
      position: fixed;
      top: 88px;
      right: 20px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 10px;
      max-width: 340px;
      width: calc(100% - 40px);
    }

    .flash-toast {
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 13px 16px;
      border-radius: 12px;
      box-shadow: 0 6px 24px rgba(0, 0, 0, 0.13);
      font-size: 0.9rem;
      font-weight: 500;
      line-height: 1.45;
      animation: toastIn 0.3s ease forwards;
    }

    @keyframes toastIn {
      from {
        opacity: 0;
        transform: translateX(50px)
      }

      to {
        opacity: 1;
        transform: none
      }
    }

    @keyframes toastOut {
      from {
        opacity: 1;
        transform: none
      }

      to {
        opacity: 0;
        transform: translateX(50px)
      }
    }

    .flash-toast.hiding {
      animation: toastOut 0.25s ease forwards;
    }

    .flash-toast.success {
      background: #f0fdf4;
      border: 1px solid #86efac;
      color: #166534;
    }

    .flash-toast.error {
      background: #fff1f2;
      border: 1px solid #fca5a5;
      color: #991b1b;
    }

    .flash-icon {
      font-size: 1.1rem;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .flash-toast.success .flash-icon {
      color: #16a34a;
    }

    .flash-toast.error .flash-icon {
      color: #dc2626;
    }

    .flash-close {
      margin-left: auto;
      background: none;
      border: none;
      cursor: pointer;
      opacity: .4;
      padding: 0;
      color: inherit;
    }

    .flash-close:hover {
      opacity: 1;
    }

    .flash-progress {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 3px;
      border-radius: 0 0 12px 12px;
      animation: shrink 4.5s linear forwards;
    }

    @keyframes shrink {
      from {
        width: 100%
      }

      to {
        width: 0
      }
    }

    .flash-toast.success .flash-progress {
      background: #16a34a;
    }

    .flash-toast.error .flash-progress {
      background: #dc2626;
    }
  </style>
</head>

<body>

  <!-- ══ NAVBAR ══ -->
  <nav class="navbar navbar-expand-lg fixed-top" id="mainNavbar">
    <div class="container-fluid px-3 px-lg-5">

      <a class="navbar-brand" href="/listings">
        <i class="fas fa-compass"></i> WonderLust
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navMain">
        <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">

          <% const isAuthPage=(currentPath==='/login' || currentPath==='/signup' ); %>

            <% if (!isAuthPage) { %>

              <!-- All Listings -->
              <li class="nav-item">
                <a class="nav-link <%= currentPath === '/listings' ? 'active-nav' : '' %>" href="/listings">
                  <i class="fas fa-globe"></i> All Listings
                </a>
              </li>

              <% if (currentUser) { %>

                <!-- My Listings -->
                <li class="nav-item">
                  <a class="nav-link <%= currentPath === '/my-listings' ? 'active-nav' : '' %>" href="/my-listings"
                    style="position:relative">
                    <i class="fas fa-home"></i> My Listings
                    <% if (myListingCount> 0) { %>
                      <span class="nav-badge">
                        <%= myListingCount %>
                      </span>
                      <% } %>
                  </a>
                </li>

                <!-- My Bookings -->
                <li class="nav-item">
                  <a class="nav-link <%= currentPath === '/my-bookings' ? 'active-nav' : '' %>" href="/my-bookings"
                    style="position:relative">
                    <i class="fas fa-calendar-check"></i> Bookings
                    <% if (bookingCount> 0) { %>
                      <span class="nav-badge">
                        <%= bookingCount %>
                      </span>
                      <% } %>
                  </a>
                </li>

                <!-- Add Listing -->
                <li class="nav-item">
                  <a class="nav-link <%= currentPath === '/listings/new' ? 'active-nav' : '' %>" href="/listings/new">
                    <i class="fas fa-plus-circle"></i> Add Listing
                  </a>
                </li>

                <% } %>

                  <li class="nav-item d-none d-lg-flex align-items-center">
                    <span class="nav-divider"></span>
                  </li>

                  <% if (currentUser) { %>
                    <!-- User chip -->
                    <li class="nav-item d-flex align-items-center">
                      <div class="user-chip">
                        <div class="avatar">
                          <%= currentUser.email.charAt(0).toUpperCase() %>
                        </div>
                        <span class="email-text">
                          <%= currentUser.email %>
                        </span>
                      </div>
                    </li>
                    <li class="nav-item">
                      <a class="nav-link btn-logout" href="/logout">
                        <i class="fas fa-sign-out-alt"></i> Logout
                      </a>
                    </li>
                    <% } else { %>
                      <li class="nav-item">
                        <a class="nav-link btn-nav-login" href="/login">
                          <i class="fas fa-sign-in-alt"></i> Log In
                        </a>
                      </li>
                      <li class="nav-item">
                        <a class="nav-link btn-nav-signup" href="/signup">
                          <i class="fas fa-user-plus"></i> Sign Up
                        </a>
                      </li>
                      <% } %>

                        <% } else { %>
                          <% if (currentUser) { %>
                            <li class="nav-item">
                              <a class="nav-link" href="/listings"><i class="fas fa-arrow-left"></i> Back to
                                Listings</a>
                            </li>
                            <% } %>
                              <% } %>

        </ul>
      </div>
    </div>
  </nav>

  <!-- ══ FLASH TOASTS ══ -->
  <div class="flash-container">
    <% if (successMsg) { %>
      <div class="flash-toast success">
        <i class="fas fa-check-circle flash-icon"></i>
        <span>
          <%= successMsg %>
        </span>
        <button class="flash-close"><i class="fas fa-times"></i></button>
        <div class="flash-progress"></div>
      </div>
      <% } %>
        <% if (errorMsg) { %>
          <div class="flash-toast error">
            <i class="fas fa-exclamation-circle flash-icon"></i>
            <span>
              <%= errorMsg %>
            </span>
            <button class="flash-close"><i class="fas fa-times"></i></button>
            <div class="flash-progress"></div>
          </div>
          <% } %>
  </div>

  <script>
    window.addEventListener("scroll", () => {
      document.getElementById("mainNavbar").classList.toggle("scrolled", window.scrollY > 40);
    });
    function dismissToast(t) {
      t.classList.add('hiding');
      t.addEventListener('animationend', () => t.remove(), { once: true });
    }
    document.querySelectorAll('.flash-toast').forEach(t => {
      t.querySelector('.flash-close').addEventListener('click', () => dismissToast(t));
      setTimeout(() => { if (document.contains(t)) dismissToast(t); }, 4500);
    });
  </script>